APP_NAME=ai-processing-service

# OpenAI
GOOGLE_API_KEY=AIza...your-google-key...

# AWS
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key
AWS_ENDPOINT_URL=  # Leave empty for real AWS, set to http://localstack:4566 for LocalStack
S3_BUCKET_NAME=architecture-diagrams
SQS_QUEUE_URL=https://sqs.us-east-1.amazonaws.com/123456789/diagram-analysis-queue

# Service URLs
UPLOAD_SERVICE_URL=http://upload-service:8001
REPORT_SERVICE_URL=http://report-service:8003

# Internal auth
INTERNAL_SERVICE_TOKEN=change-me-in-production
